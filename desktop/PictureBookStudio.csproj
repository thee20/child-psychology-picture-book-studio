<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>PictureBookStudio</AssemblyName>
    <RootNamespace>PictureBookStudio</RootNamespace>
    <ApplicationIcon>..\app.ico</ApplicationIcon>
    <!-- WebView2 package also ships a WPF assembly that conflicts with net6 WindowsBase refs (MSB3277 noise). -->
    <MSBuildWarningsAsMessages>$(MSBuildWarningsAsMessages);MSB3277</MSBuildWarningsAsMessages>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3650.58" />
  </ItemGroup>
  <!-- WinForms shell only: drop WPF WebView2 assembly from compile/runtime graph when present. -->
  <Target Name="ExcludeWebView2Wpf" BeforeTargets="ResolveAssemblyReferences">
    <ItemGroup>
      <ReferencePath Remove="@(ReferencePath)" Condition="'%(Filename)' == 'Microsoft.Web.WebView2.Wpf'" />
      <Reference CopyLocal="false" Condition="'%(Filename)' == 'Microsoft.Web.WebView2.Wpf'" />
    </ItemGroup>
  </Target>
</Project>
